# Copy to .env and fill in. The CLI auto-loads .env (Node process.loadEnvFile).

# Anthropic API key for the adjudicator (Claude Haiku 4.5)
ANTHROPIC_API_KEY=sk-ant-...

# Path to the built ledger CLI binary (used to read the active project + next action, and — with
# BULWORK_PLAN_BACKEND=ledger below — the workload plan/templates too).
# Defaults to the repo path below if unset.
LEDGER_BIN=/path/to/ledger-cli

# Workload plan/template backend (Epic D): "local" (default, .data/plan.json + templates.json) or
# "ledger" (Firestore, via LEDGER_BIN's `plan`/`template` verbs). Requires LEDGER_BIN + Firestore
# creds (GOOGLE_APPLICATION_CREDENTIALS or gcloud ADC).
# BULWORK_PLAN_BACKEND=ledger

# Optional overrides
# BULWORK_MODEL=claude-haiku-4-5   (deprecated BRICK_MODEL still works as a fallback)
# A block verdict below this confidence is downgraded to allow (conservative-allow).
# BULWORK_MIN_BLOCK_CONFIDENCE=0.6   (deprecated BRICK_MIN_BLOCK_CONFIDENCE still works)
